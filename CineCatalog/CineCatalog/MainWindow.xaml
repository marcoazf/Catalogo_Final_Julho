<Window x:Class="CineCatalog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CineCatalog.ViewModels"
        xmlns:views="clr-namespace:CineCatalog.Views"
        xmlns:conv="clr-namespace:CineCatalog.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="{Binding TitleBar}"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgColor}"
        Foreground="{DynamicResource TextColor}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="VisConv" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#3B82F6" CornerRadius="8"
                            Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="🎬" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="CineCatalog Elo" FontSize="16" FontWeight="Black"
                                   FontStyle="Italic" Foreground="{DynamicResource TextColor}" />
                        <TextBlock Text="Premium Desktop v2.0" FontSize="7" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="ATUALIZAR" Command="{Binding RefreshCommand}"
                            Padding="16,8" FontSize="9" FontWeight="Black"
                            Background="{DynamicResource InputBg}"
                            Foreground="{DynamicResource TextColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="16" Cursor="Hand"
                            Margin="0,0,8,0" />
                    <Button Content="CONFIG" Command="{Binding ShowSettingsCommand}"
                            Padding="16,8" FontSize="9" FontWeight="Black"
                            Background="{DynamicResource InputBg}"
                            Foreground="{DynamicResource TextColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="16" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="2">
            <!-- Catalog view (default) -->
            <views:CatalogView x:Name="CatalogContent" Visibility="Visible" />

            <!-- Settings view -->
            <views:SettingsView x:Name="SettingsContent" Visibility="Collapsed" />
        </Grid>

        <!-- Footer status -->
        <Border Grid.Row="3" Background="{DynamicResource HeaderBg}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                Padding="24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Catalog.StatusMessage}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondary}" />

                <TextBlock Grid.Column="1"
                           FontSize="9" FontWeight="Black"
                           Foreground="{DynamicResource TextMuted}">
                    <Run Text="{Binding Catalog.FilteredCount}" />
                    <Run Text=" / " />
                    <Run Text="{Binding Catalog.TotalCount}" />
                    <Run Text=" TÍTULOS NO ACERVO" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
