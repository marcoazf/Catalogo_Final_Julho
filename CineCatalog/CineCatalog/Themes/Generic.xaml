<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme (default) -->
    <SolidColorBrush x:Key="BgColor" Color="#111827" />
    <SolidColorBrush x:Key="TextColor" Color="#F3F4F6" />
    <SolidColorBrush x:Key="HeaderBg" Color="#111827" />
    <SolidColorBrush x:Key="CardBg" Color="#1F2937" />
    <SolidColorBrush x:Key="InputBg" Color="#1F2937" />
    <SolidColorBrush x:Key="BorderColor" Color="#374151" />
    <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF" />
    <SolidColorBrush x:Key="TextMuted" Color="#6B7280" />
    <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
    <SolidColorBrush x:Key="Success" Color="#10B981" />
    <SolidColorBrush x:Key="Warning" Color="#F59E0B" />
    <SolidColorBrush x:Key="Error" Color="#EF4444" />

</ResourceDictionary>
