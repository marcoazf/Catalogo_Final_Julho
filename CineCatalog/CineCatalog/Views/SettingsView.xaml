<UserControl x:Class="CineCatalog.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CineCatalog.ViewModels"
             xmlns:conv="clr-namespace:CineCatalog.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="VisConv" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgColor}" Padding="32">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock Text="CONFIGURAÇÕES" FontSize="24" FontWeight="Black"
                       Foreground="{DynamicResource TextColor}" Margin="0,0,0,32" />

            <!-- Theme -->
            <TextBlock Text="Tema" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Button Content="ESCURO" Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                        Padding="24,10" FontSize="10" FontWeight="Black" Margin="0,0,8,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource InputBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Theme}" Value="Dark">
                                    <Setter Property="Background" Value="#3B82F6" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="CLARO" Command="{Binding SetThemeCommand}" CommandParameter="Light"
                        Padding="24,10" FontSize="10" FontWeight="Black" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource InputBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Theme}" Value="Light">
                                    <Setter Property="Background" Value="#3B82F6" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Data info -->
            <TextBlock Text="Dados" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" />
            <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource TextColor}" FontSize="12">
                        <Run Text="Total no catálogo: " />
                        <Run Text="{Binding TotalItems}" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,8,0,0"
                               Text="{Binding DataPath, StringFormat='Local: {0}'}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="ABRIR PASTA" Command="{Binding OpenDataFolderCommand}"
                                Padding="16,8" FontSize="9" FontWeight="Black" Margin="0,0,8,0"
                                Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextColor}"
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                CornerRadius="8" Cursor="Hand" />
                        <Button Content="LIMPAR CATÁLOGO" Command="{Binding ClearDataCommand}"
                                Padding="16,8" FontSize="9" FontWeight="Black"
                                Background="#EF4444" Foreground="White" BorderThickness="0"
                                CornerRadius="8" Cursor="Hand" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Version -->
            <TextBlock Text="CineCatalog Elo v2.0"
                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center" Margin="0,32,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
